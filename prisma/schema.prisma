generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Multi-Tenant: Organizations ────────────────────────────────
model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  logo        String?
  plan        Plan     @default(FREE)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members      OrganizationMember[]
  clients      Client[]
  scenarios    Scenario[]
  reports      Report[]
  integrations Integration[]
  metrics      Metric[]

  @@map("organizations")
}

enum Plan {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

// ─── Users ──────────────────────────────────────────────────────
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  image         String?
  globalRole    GlobalRole @default(USER)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  memberships   OrganizationMember[]
  sessions      Session[]
  accounts      Account[]

  @@map("users")
}

enum GlobalRole {
  SUPER_ADMIN
  USER
}

// ─── Organization Membership (Role per Org) ─────────────────────
model OrganizationMember {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           OrgRole        @default(VIEWER)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@map("organization_members")
}

enum OrgRole {
  OWNER
  ADMIN
  EDITOR
  VIEWER
}

// ─── NextAuth Accounts & Sessions ───────────────────────────────
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Clients (per Organization) ─────────────────────────────────
model Client {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  industry       String?
  website        String?
  contactEmail   String?
  contactPhone   String?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  scenarios      Scenario[]
  integrations   Integration[]

  @@map("clients")
}

// ─── Scenarios ──────────────────────────────────────────────────
model Scenario {
  id             String       @id @default(cuid())
  organizationId String
  clientId       String?
  title          String
  description    String?
  status         ScenarioStatus @default(DRAFT)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@map("scenarios")
}

enum ScenarioStatus {
  DRAFT
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

// ─── Reports ────────────────────────────────────────────────────
model Report {
  id             String       @id @default(cuid())
  organizationId String
  title          String
  type           ReportType
  data           Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("reports")
}

enum ReportType {
  EMOTION_ANALYSIS
  SENTIMENT_TREND
  ENGAGEMENT
  CUSTOM
}

// ─── Platform Integrations ──────────────────────────────────────
model Integration {
  id             String       @id @default(cuid())
  organizationId String
  clientId       String?
  platform       Platform
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  externalId     String?      // Platform-specific account/page ID
  externalName   String?      // Display name from the platform
  scopes         String?      // Comma-separated scopes granted
  status         IntegrationStatus @default(DISCONNECTED)
  lastSyncAt     DateTime?
  lastSyncError  String?
  metadata       Json?        // Platform-specific config
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client         Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  metrics        Metric[]

  @@unique([organizationId, platform, externalId])
  @@map("integrations")
}

enum Platform {
  GOOGLE_ANALYTICS
  SEARCH_CONSOLE
  INSTAGRAM
  FACEBOOK
  YOUTUBE
  LINKEDIN
  TIKTOK
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  SYNCING
}

// ─── Metrics (Time-series data from platforms) ──────────────────
model Metric {
  id             String   @id @default(cuid())
  organizationId String
  integrationId  String
  platform       Platform
  metricName     String   // e.g. "sessions", "followers", "impressions"
  metricValue    Float
  dimensions     Json?    // e.g. {"source": "organic", "query": "keyword"}
  period         String   // e.g. "2026-04-09", "2026-W15"
  collectedAt    DateTime @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  integration    Integration  @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([organizationId, platform, metricName, period])
  @@index([integrationId, metricName, period])
  @@map("metrics")
}
